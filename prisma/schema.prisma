generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String
  age            Int
  parentEmail    String?
  parentVerified Boolean  @default(false)
  role           String   @default("user")
  isBanned       Boolean  @default(false)
  dailyLimit     Int      @default(180)
  warnCount      Int      @default(0)
  createdAt      DateTime @default(now())

  ownedRooms      Room[]
  reportsGiven    Report[] @relation("Reporter")
  reportsReceived Report[] @relation("Reported")
  modLogs         ModLog[]
  sessions        UsageSession[]
  blocks          UserBlock[] @relation("Blocker")
  blockedBy       UserBlock[] @relation("Blocked")
}

model Room {
  id          String   @id @default(uuid())
  name        String
  category    String   @default("genel")
  ageMin      Int      @default(10)
  ageMax      Int      @default(18)
  maxUsers    Int      @default(10)
  ownerId     String?
  inviteOnly  Boolean  @default(false)
  isActive    Boolean  @default(true)
  hmsRoomId   String?  @unique
  createdAt   DateTime @default(now())

  owner    User?  @relation(fields: [ownerId], references: [id])
  reports  Report[]
  modLogs  ModLog[]
  sessions UsageSession[]
}

model Report {
  id             String   @id @default(uuid())
  reporterId     String
  reportedUserId String
  roomId         String?
  reason         String
  description    String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())

  reporter     User  @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser User  @relation("Reported", fields: [reportedUserId], references: [id])
  room         Room? @relation(fields: [roomId], references: [id])
}

model ModLog {
  id            String   @id @default(uuid())
  userId        String
  roomId        String?
  violationType String
  transcript    String?
  actionTaken   String
  createdAt     DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  room Room? @relation(fields: [roomId], references: [id])
}

model UsageSession {
  id              String    @id @default(uuid())
  userId          String
  roomId          String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  durationMinutes Int?

  user User  @relation(fields: [userId], references: [id])
  room Room? @relation(fields: [roomId], references: [id])
}

model UserBlock {
  blockerId String
  blockedId String

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}
