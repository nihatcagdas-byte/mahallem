# ── Sunucu ──────────────────────────────────────
PORT=3001
NODE_ENV=production

# Frontend URL (Netlify'a deploy ettikten sonra güncelle)
FRONTEND_URL=https://mahallem.netlify.app

# ── Supabase Veritabanı ──────────────────────────
# supabase.com → Proje → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[ŞİFRE]@db.[PROJE-ID].supabase.co:5432/postgres

# ── JWT ─────────────────────────────────────────
# En az 64 rastgele karakter yaz (örn: klavyede rastgele tuşlara bas)
JWT_SECRET=buraya_en_az_64_karakterlik_cok_uzun_rastgele_bir_sifre_yazmalısin_abc123xyz
JWT_EXPIRES_IN=7d

# ── 100ms WebRTC ─────────────────────────────────
# dashboard.100ms.live → Developer → App Access Key & Secret
HMS_ACCESS_KEY=buraya_100ms_access_key
HMS_SECRET=buraya_100ms_secret

# ── Groq (Ücretsiz Whisper AI) ───────────────────
# console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_buraya_groq_api_key

# ── Upstash Redis ────────────────────────────────
# console.upstash.com → Redis → Create → REST URL ve TOKEN
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=buraya_upstash_token
